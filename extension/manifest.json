{
  "manifest_version": 3,
  "name": "Rosemary",
  "version": "1.0.0",
  "description": "Rosemary v1.0.0 — Tunneling dashboard for managing agents, port forwards, routes and logs from your browser toolbar.",
  "permissions": ["storage", "cookies"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
